{
  "explorer.fileNesting.enabled": true,
  "explorer.fileNesting.expand": false,
  "explorer.fileNesting.patterns": {
    "*.go": "${capture}_test.go",
    "*.ts": "${capture}.test.ts",
    "*.tsx": "${capture}.test.tsx",
    "package.json": "package-lock.json"
  },
  "files.associations": {
    "*.css": "tailwindcss"
  },
  "js/ts.tsdk.path": "frontend/node_modules/typescript/lib"
}
